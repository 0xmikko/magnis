{
  "id": "telegram",
  "version": "0.1.0",
  "magnis_api_version": "0.1.0",
  "owns": [
    "telegram.*"
  ],
  "requires_schemas": [
    "contacts.person"
  ],
  "schemas": {
    "entities": [
      {
        "id": "telegram.account",
        "name": "Telegram account",
        "description": "A telegram account entity owned by the telegram plugin."
      },
      {
        "id": "telegram.chat",
        "name": "Telegram chat",
        "description": "A telegram chat/dialog entity.",
        "triggerable": true
      },
      {
        "id": "telegram.message",
        "name": "Telegram message",
        "description": "A telegram message entity."
      }
    ],
    "facets": [
      {
        "id": "telegram.account.details",
        "entity_schema": "telegram.account",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "account_id": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "auth_state": {
              "type": "string"
            }
          },
          "required": [
            "account_id"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "phone",
            "canonical_key": "telegram.account.phone",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "username",
            "canonical_key": "telegram.account.username",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "telegram.chat.details",
        "entity_schema": "telegram.chat",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "chat_id": {
              "type": "integer"
            },
            "entity_type": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "avatar_url": {
              "type": "string"
            },
            "is_pinned": {
              "type": "boolean"
            },
            "pin_order": {
              "type": "integer"
            },
            "unread_count": {
              "type": "integer"
            },
            "unread_mark": {
              "type": "boolean"
            },
            "unread_mentions_count": {
              "type": "integer"
            },
            "read_inbox_max_id": {
              "type": "integer"
            },
            "read_outbox_max_id": {
              "type": "integer"
            },
            "top_message": {
              "type": "integer"
            },
            "pts": {
              "type": "integer"
            },
            "member_count": {
              "type": "integer"
            },
            "is_indexed": {
              "type": "boolean"
            },
            "last_message_date": {
              "type": "string"
            },
            "last_message_preview": {
              "type": "string"
            },
            "last_sender_name": {
              "type": "string"
            },
            "members": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "integer"
                  },
                  "first_name": {
                    "type": "string"
                  },
                  "last_name": {
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "required": [
            "chat_id",
            "title",
            "type"
          ],
          "additionalProperties": true
        },
        "mappings": [
          {
            "facet_path": "title",
            "canonical_key": "telegram.chat.title",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "telegram.message.details",
        "entity_schema": "telegram.message",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "message_id": {
              "type": "integer"
            },
            "text": {
              "type": "string"
            },
            "date": {
              "type": "string",
              "format": "date-time"
            },
            "chat_id": {
              "type": "integer"
            },
            "chat_title": {
              "type": "string"
            },
            "sender_name": {
              "type": "string"
            },
            "sender_id": {
              "type": "integer"
            },
            "sender_info": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "first_name": {
                  "type": "string"
                },
                "last_name": {
                  "type": "string"
                },
                "username": {
                  "type": "string"
                },
                "phone": {
                  "type": "string"
                }
              }
            },
            "reply_to_msg_id": {
              "type": "integer"
            },
            "is_outgoing": {
              "type": "boolean"
            },
            "media_type": {
              "type": "string"
            },
            "media_url": {
              "type": "string"
            },
            "is_pinned": {
              "type": "boolean"
            },
            "file_name": {
              "type": "string"
            },
            "sender_avatar_url": {
              "type": "string"
            }
          },
          "required": [
            "message_id"
          ],
          "additionalProperties": true
        },
        "mappings": [
          {
            "facet_path": "text",
            "canonical_key": "telegram.message.text",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "sender_name",
            "canonical_key": "telegram.message.sender",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "telegram.contact",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "telegram_user_id": {
              "type": "integer"
            },
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "photo_url": {
              "type": "string"
            },
            "avatar_url": {
              "type": "string"
            },
            "relevance_tier": {
              "type": "string"
            }
          },
          "required": [
            "telegram_user_id",
            "first_name"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "first_name",
            "canonical_key": "person.first_name",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "last_name",
            "canonical_key": "person.last_name",
            "strategy": "single_aligned"
          }
        ]
      }
    ],
    "links": []
  },
  "capabilities": {
    "facet_write_prefixes": [
      "telegram."
    ],
    "link_kinds_writable": [
      "telegram.message:telegram.chat",
      "telegram.message:person",
      "person:telegram.chat"
    ],
    "reads_schemas": [
      "telegram.",
      "contacts.person"
    ],
    "events_emitted": [],
    "can_merge_schemas": [
      "telegram.account",
      "telegram.chat",
      "telegram.message"
    ],
    "creates_schemas": [
      "contacts.person"
    ],
    "rpc_calls": [
      "triggers.create"
    ],
    "op_grants": [
      "source_commands",
      "sync_state",
      "composer",
      "file_register",
      "web_register",
      "external_id_reads"
    ]
  },
  "surfaces": {
    "rpc_handlers": [
      "telegram.chats.list",
      "telegram.messages.list",
      "telegram.messages.get",
      "telegram.chats.set_indexed",
      "telegram.messages.send",
      "telegram.messages.reply",
      "telegram.batch_send",
      "telegram.messages.backfill",
      "telegram.sync.status",
      "telegram.sync.reset",
      "telegram.composer.read",
      "telegram.composer.set_text",
      "telegram.composer.append_text",
      "telegram.set_trigger"
    ],
    "tools": [
      "telegram.chats.list",
      "telegram.messages.list",
      "telegram.messages.get",
      "telegram.messages.send",
      "telegram.messages.reply",
      "telegram.batch_send",
      "telegram.set_trigger"
    ],
    "sync_handlers": [
      "telegram"
    ]
  },
  "entry": {
    "module": "module/index.ts",
    "ui": "index.tsx"
  },
  "ui": {
    "extra_bare_imports": [
      "react-virtuoso",
      "zustand",
      "zustand/vanilla"
    ]
  },
  "presentation": {
    "title": "Telegram Messages",
    "summary": "Threaded Telegram chats indexed alongside the rest of your graph.",
    "publisher": "Magnis",
    "publisher_url": "https://magnis.ai",
    "details": "# Telegram Messages\n\nTelegram chats ingested as first-class messages — threaded,\nsearchable, and linked to the contacts and projects they belong to.\nPairs with the Telegram source for live sync.\n",
    "icon_url": "/api/plugins/telegram/ui/icon.svg"
  },
  "lifecycle": {
    "install": "lifecycle/install.ts"
  }
}
