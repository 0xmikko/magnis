{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "experimentalDecorators": true
  },
  "include": [
    "module/**/*.ts",
    "types/**/*.ts",
    "ui/**/*.ts",
    "ui/**/*.tsx"
