{
  "id": "file",
  "version": "0.1.0",
  "magnis_api_version": "0.1.0",
  "owns": [
    "file.*"
  ],
  "schemas": {
    "entities": [
      {
        "id": "file.object",
        "name": "File",
        "description": "File or media attachment entity. Written by core FileService (storage engine); this plugin owns the schema + the read/manage surface."
      }
    ],
    "facets": [
      {
        "id": "file.details",
        "entity_schema": "file.object",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": [
                "string",
                "null"
              ]
            },
            "mime_type": {
              "type": "string"
            },
            "size_bytes": {
              "type": [
                "integer",
                "null"
              ]
            },
            "local_path": {
              "type": [
                "string",
                "null"
              ]
            },
            "cloud_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "source_module": {
              "type": "string"
            },
            "source_ref": {
              "type": "object"
            }
          },
          "required": [
            "mime_type",
            "source_module",
            "source_ref"
          ],
          "additionalProperties": true
        }
      },
      {
        "id": "file.image",
        "entity_schema": "file.object",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            }
          },
          "required": [
            "width",
            "height"
          ],
          "additionalProperties": true
        }
      },
      {
        "id": "file.audio",
        "entity_schema": "file.object",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "duration_seconds": {
              "type": "number"
            }
          },
          "required": [
            "duration_seconds"
          ],
          "additionalProperties": true
        }
      },
      {
        "id": "file.video",
        "entity_schema": "file.object",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "duration_seconds": {
              "type": "number"
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            }
          },
          "required": [
            "duration_seconds",
            "width",
            "height"
          ],
          "additionalProperties": true
        }
      }
    ],
    "links": []
  },
  "capabilities": {
    "facet_write_prefixes": [],
    "link_kinds_writable": [
      "attachment"
    ],
    "rpc_calls": [],
    "reads_schemas": [
      "file."
    ],
    "events_emitted": [],
    "can_merge_schemas": []
  },
  "surfaces": {
    "rpc_handlers": [
      "file.list",
      "file.get",
      "file.attach"
    ],
    "tools": [
      "file.list",
      "file.get",
      "file.attach"
    ],
    "sync_handlers": []
  },
  "entry": {
    "module": "module/index.ts",
    "ui": "index.tsx"
  },
  "presentation": {
    "title": "Files",
    "summary": "Documents and attachments from your sources, in one place.",
    "publisher": "Magnis",
    "publisher_url": "https://magnis.ai",
    "details": "# Files\n\nFiles and attachments ingested from email and other sources, linked to\nthe people, companies, and projects they belong to. Browse, open, and\nattach files across your graph.\n",
    "icon_url": "/api/plugins/file/ui/icon.svg"
  },
  "lifecycle": {
    "install": "lifecycle/install.ts"
  }
}
