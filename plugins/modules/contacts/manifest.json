{
  "id": "contacts",
  "version": "0.1.0",
  "magnis_api_version": "0.1.0",
  "owns": [
    "contacts.*"
  ],
  "schemas": {
    "entities": [
      {
        "id": "contacts.person",
        "name": "Person",
        "description": "A person / contact entity owned by the contacts plugin."
      }
    ],
    "facets": [
      {
        "id": "contacts.person.profile",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "birthday": {
              "type": "string"
            },
            "bio": {
              "type": "string"
            },
            "is_bot": {
              "type": "boolean"
            },
            "is_verified": {
              "type": "boolean"
            },
            "is_scam": {
              "type": "boolean"
            },
            "is_fake": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "first_name",
            "canonical_key": "person.first_name",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "last_name",
            "canonical_key": "person.last_name",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "username",
            "canonical_key": "person.username",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "birthday",
            "canonical_key": "person.birthday",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "bio",
            "canonical_key": "person.bio",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "contacts.person.email",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "is_primary": {
              "type": "boolean"
            }
          },
          "required": [
            "email"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "email",
            "canonical_key": "person.emails",
            "strategy": "collection"
          }
        ]
      },
      {
        "id": "contacts.person.phone",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "phone": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "is_primary": {
              "type": "boolean"
            }
          },
          "required": [
            "phone"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "phone",
            "canonical_key": "person.phones",
            "strategy": "collection"
          }
        ]
      },
      {
        "id": "contacts.person.external_link",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "source_type": {
              "type": "string"
            },
            "external_id": {
              "type": "string"
            },
            "external_url": {
              "type": "string"
            },
            "external_name": {
              "type": "string"
            }
          },
          "required": [
            "source_type",
            "external_id"
          ],
          "additionalProperties": false
        }
      },
      {
        "id": "contacts.person.name_history",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "username": {
              "type": "string"
            },
            "recorded_at": {
              "type": "string",
              "format": "date-time"
            }
          },
          "additionalProperties": false
        }
      },
      {
        "id": "contacts.identity.telegram",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "telegram_user_id": {
              "type": "integer"
            },
            "username": {
              "type": "string"
            },
            "first_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "phone": {
              "type": "string"
            },
            "bio": {
              "type": "string"
            },
            "is_bot": {
              "type": "boolean"
            },
            "is_verified": {
              "type": "boolean"
            },
            "is_scam": {
              "type": "boolean"
            },
            "is_fake": {
              "type": "boolean"
            }
          },
          "required": [
            "telegram_user_id"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "username",
            "canonical_key": "person.telegram_username",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "telegram_user_id",
            "canonical_key": "person.telegram_id",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "contacts.description",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "body": {
              "type": "string"
            }
          },
          "required": [
            "body"
          ],
          "additionalProperties": false
        }
      },
      {
        "id": "contacts.memory",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "body": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "body"
          ],
          "additionalProperties": false
        }
      },
      {
        "id": "contacts.person.social",
        "entity_schema": "contacts.person",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "tracked_x": {
              "type": "boolean"
            },
            "x_handle": {
              "type": "string"
            },
            "tracked_linkedin": {
              "type": "boolean"
            },
            "linkedin_handle": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      }
    ],
    "links": []
  },
  "capabilities": {
    "facet_write_prefixes": [
      "contacts."
    ],
    "link_kinds_writable": [
      "has_email"
    ],
    "rpc_calls": [
      "email.ensure_address"
    ],
    "reads_schemas": [
      "contacts.",
      "companies.company"
    ],
    "events_emitted": [],
    "can_merge_schemas": [
      "contacts.person"
    ]
  },
  "surfaces": {
    "rpc_handlers": [
      "contacts.list",
      "contacts.get",
      "contacts.search",
      "contacts.create",
      "contacts.batch_create",
      "contacts.update",
      "contacts.merge_preview",
      "contacts.merge",
      "contacts.set_social_tracking",
      "contacts.get_social_tracking",
      "contacts.get_social_tracking_by_handle",
      "contacts.list_social_tracking",
      "contacts.track_social_profile",
      "contacts.batch_track_social",
      "contacts.rename_if_placeholder"
    ],
    "tools": [
      "contacts.list",
      "contacts.get",
      "contacts.search",
      "contacts.create",
      "contacts.batch_create",
      "contacts.update",
      "contacts.merge_preview",
      "contacts.merge",
      "contacts.set_social_tracking",
      "contacts.get_social_tracking",
      "contacts.get_social_tracking_by_handle",
      "contacts.list_social_tracking",
      "contacts.track_social_profile",
      "contacts.batch_track_social"
    ],
    "sync_handlers": [
      "contacts"
    ]
  },
  "entry": {
    "module": "module/index.ts",
    "ui": "index.tsx"
  },
  "presentation": {
    "title": "Contacts",
    "summary": "People from every source, merged into one identity.",
    "publisher": "Magnis",
    "publisher_url": "https://magnis.ai",
    "details": "# Contacts\n\nA single graph of every person you know, automatically merged from\nemail, calendar, and chat. Contacts learns identity from every\nconnected source and keeps one canonical record per person.\n\n- Unified profile with provenance for every field\n- Automatic merge across email addresses and handles\n- Links to companies, meetings, and conversations\n",
    "icon_url": "/api/plugins/contacts/ui/icon.svg"
  },
  "lifecycle": {
    "install": "lifecycle/install.ts"
  }
}