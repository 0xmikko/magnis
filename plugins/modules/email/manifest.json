{
  "id": "email",
  "version": "0.1.0",
  "magnis_api_version": "0.1.0",
  "owns": [
    "email.*"
  ],
  "schemas": {
    "entities": [
      {
        "id": "email.message",
        "name": "Email message",
        "description": "An email message entity owned by the email plugin."
      },
      {
        "id": "email.address",
        "name": "Email address",
        "description": "An email address entity (sender/recipient hub).",
        "triggerable": true
      }
    ],
    "facets": [
      {
        "id": "email.message.details",
        "entity_schema": "email.message",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "message_id": {
              "type": "string"
            },
            "subject": {
              "type": [
                "string",
                "null"
              ]
            },
            "from_address": {
              "type": [
                "string",
                "null"
              ]
            },
            "from_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "to_addresses": {
              "type": [
                "string",
                "null"
              ]
            },
            "cc_addresses": {
              "type": [
                "string",
                "null"
              ]
            },
            "bcc_addresses": {
              "type": [
                "string",
                "null"
              ]
            },
            "snippet": {
              "type": [
                "string",
                "null"
              ]
            },
            "body_text": {
              "type": [
                "string",
                "null"
              ]
            },
            "body_html": {
              "type": [
                "string",
                "null"
              ]
            },
            "has_html_body": {
              "type": "boolean"
            },
            "sent_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "received_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "labels": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "is_read": {
              "type": "boolean"
            },
            "is_starred": {
              "type": "boolean"
            },
            "is_important": {
              "type": "boolean"
            },
            "has_attachments": {
              "type": "boolean"
            },
            "thread_id": {
              "type": "string"
            },
            "attachments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "mime_type": {
                    "type": "string"
                  },
                  "size": {
                    "type": "integer"
                  },
                  "path": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "additionalProperties": true
        },
        "mappings": [
          {
            "facet_path": "from_address",
            "canonical_key": "email.message.sender",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "subject",
            "canonical_key": "email.message.subject",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "snippet",
            "canonical_key": "email.message.preview",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "body_text",
            "canonical_key": "email.message.body",
            "strategy": "single_aligned"
          },
          {
            "facet_path": "from_name",
            "canonical_key": "email.message.sender_name",
            "strategy": "single_aligned"
          }
        ]
      },
      {
        "id": "email.address.details",
        "entity_schema": "email.address",
        "version": 1,
        "json_schema": {
          "type": "object",
          "properties": {
            "address": {
              "type": "string"
            },
            "display_name": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "address"
          ],
          "additionalProperties": false
        },
        "mappings": [
          {
            "facet_path": "address",
            "canonical_key": "email.address.canonical",
            "strategy": "single_aligned"
          }
        ]
      }
    ],
    "links": []
  },
  "capabilities": {
    "facet_write_prefixes": [
      "email."
    ],
    "link_kinds_writable": [
      "sent_from",
      "sent_to",
      "attachment"
    ],
    "reads_schemas": [
      "email."
    ],
    "events_emitted": [],
    "can_merge_schemas": [
      "email.message",
      "email.address"
    ],
    "rpc_calls": [
      "triggers.create"
    ],
    "op_grants": [
      "file_register",
      "external_id_reads",
      "source_commands",
      "sync_state",
      "composer"
    ]
  },
  "surfaces": {
    "rpc_handlers": [
      "email.list",
      "email.get",
      "email.batch",
      "email.send",
      "email.reply",
      "email.batch_send",
      "email.set_trigger",
      "email.ensure_address",
      "email.sync.status",
      "email.sync.reset",
      "email.composer.read",
      "email.composer.set_text",
      "email.composer.append_text",
      "email.composer.set_attachments"
    ],
    "tools": [
      "email.list",
      "email.get",
      "email.batch",
      "email.send",
      "email.reply",
      "email.batch_send",
      "email.set_trigger"
    ],
    "sync_handlers": [
      "email"
    ],
    "sync_item_schemas": {
      "email": "email.message"
    }
  },
  "entry": {
    "module": "module/index.ts",
    "ui": "index.tsx"
  },
  "presentation": {
    "title": "Email",
    "summary": "Ingest, search, and act on email threads from any provider.",
    "publisher": "Magnis",
    "publisher_url": "https://magnis.ai",
    "details": "# Email\n\nThreaded email indexed directly into your personal graph. Works with\nany source that fulfils the `email` surface — Gmail today, more\nproviders on the roadmap.\n\n- Full-thread ingestion with covered-range tracking\n- Linked to contacts, companies, and meetings\n- Ready for agent-driven replies and summaries\n",
    "icon_url": "/api/plugins/email/ui/icon.svg"
  },
  "lifecycle": {
    "install": "lifecycle/install.ts"
  }
}
